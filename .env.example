# MongoDB Configuration
MONGODB_URL=mongodb://localhost:27017
DATABASE_NAME=breast_cancer_db

# Admin Account
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin@1234

# JWT Secret (change in production)
